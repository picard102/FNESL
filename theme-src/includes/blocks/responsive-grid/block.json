{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fnesl/responsive-grid",
  "title": "Responsive Grid",
  "category": "fnesl",
  "icon": "grid-view",
  "description": "A responsive grid container with configurable columns per breakpoint.",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": false
    },
    "color": {
      "background": true,
      "text": false
    }
  },
  "attributes": {
    "colsBase": { "type": "integer", "default": 1 },
    "colsSm":   { "type": "integer", "default": 0 },
    "colsMd":   { "type": "integer", "default": 2 },
    "colsLg":   { "type": "integer", "default": 3 },
    "colsXl":   { "type": "integer", "default": 0 },
    "cols2xl":  { "type": "integer", "default": 0 },
    "gap":      { "type": "string",  "default": "md" }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
