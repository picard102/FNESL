{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fnesl/affiliations",
  "title": "Affiliations",
  "category": "fnesl",
  "icon": "groups",
  "description": "Displays affiliation partner cards with logo, description, and link.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "mode": {
      "type": "string",
      "default": "latest"
    },
    "displayType": {
      "type": "string",
      "default": "grid"
    },
    "count": {
      "type": "integer",
      "default": 2
    },
    "pickedIds": {
      "type": "array",
      "items": { "type": "integer" },
      "default": []
    }
  },
  "editorScript": "file:./index.js",
  "script": "file:./frontend.js",
  "render": "file:./render.php"
}
